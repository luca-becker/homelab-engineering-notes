---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL; // endet mit '/'
const caseStudies = [
  {
    href: 'case-studies/observability',
    n: '01',
    title: 'Observability & Monitoring',
    summary:
      'Agentloses Monitoring-System über mehrere Hosts: 70+ Checks, Alert-Deduplizierung und -Korrelation, Kapazitäts-Forecasting und trust-gated Self-Healing.',
    tags: ['Python', 'SSH-agentless', 'Alerting', 'Forecasting'],
  },
  {
    href: 'case-studies/backup-resilience',
    n: '02',
    title: 'Backup & Resilience',
    summary:
      '3-2-1-Backup mit Echtzeit-Replikation (RPO < 1 s), verschlüsseltem Offsite-Mirror und wöchentlich automatisch verifizierten Restores statt „Backup-and-pray".',
    tags: ['Litestream', 'restic', 'RPO/RTO', 'DR-Drills'],
  },
  {
    href: 'case-studies/public-edge',
    n: '03',
    title: 'Public-Edge & Routing',
    summary:
      'Öffentliche Erreichbarkeit ohne offenen Inbound-Port: Noise-verschlüsselter Reverse-Tunnel, Reverse-Proxy mit Auto-TLS und loopback-gebundene Dienste hinter einem Secrets-Manager.',
    tags: ['Reverse-Tunnel', 'Caddy', 'Auto-TLS', 'Zero-Inbound'],
  },
];

const stack = [
  { group: 'OS & Runtime', items: 'Linux · systemd · Docker & Compose · SSH' },
  { group: 'Observability', items: 'Eigenes Check-Framework · Beszel · Scrutiny (SMART) · ntfy / Discord' },
  { group: 'Backup & DR', items: 'restic · Litestream · rsync · GPG · Restore-Verifikation' },
  { group: 'Edge & Netzwerk', items: 'Caddy (Auto-HTTPS) · Reverse-Tunnel · Vaultwarden (Secrets)' },
  { group: 'Automation & Code', items: 'Python · APScheduler · FastAPI · SQLite · Renovate' },
];
---

<BaseLayout title="Homelab Engineering Notes">
  <section class="hero">
    <p class="kicker mono">// Systems · Infrastructure · Automation Engineering</p>
    <h1>Homelab als Engineering-Übungsfeld.</h1>
    <p class="intro">
      Ich betreibe ein self-hosted Homelab, um Infrastruktur-Engineering in der Tiefe zu üben:
      <strong>Observability</strong>, <strong>Backup &amp; Resilience</strong> und sichere
      <strong>Public-Edge-Anbindung</strong> — dieselben Muster wie in produktiven Umgebungen,
      im Kleinen sauber und nachvollziehbar umgesetzt. Diese Seite dokumentiert drei Projekte
      als Case-Studies: Problem, Architektur, Entscheidungen und messbares Ergebnis.
    </p>
    <div class="contact mono">
      <span>&gt; kontakt:</span>
      <a href="mailto:REDACTED@example.dev">&lt;E-Mail&gt;</a>
      <span class="sep">·</span>
      <a href="https://github.com/REDACTED">&lt;GitHub&gt;</a>
      <span class="sep">·</span>
      <span class="muted">&lt;Ort&gt;</span>
    </div>
  </section>

  <section id="case-studies">
    <h2>Case Studies</h2>
    <div class="cards">
      {caseStudies.map((cs) => (
        <a class="card" href={`${base}${cs.href}`}>
          <div class="card-top">
            <span class="card-n mono">{cs.n}</span>
            <span class="card-arrow mono">→</span>
          </div>
          <h3>{cs.title}</h3>
          <p>{cs.summary}</p>
          <div class="card-tags">
            {cs.tags.map((t) => <span class="mono">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section id="stack">
    <h2>Stack &amp; Kompetenzen</h2>
    <div class="stack">
      {stack.map((s) => (
        <div class="stack-row">
          <div class="stack-group mono">{s.group}</div>
          <div class="stack-items">{s.items}</div>
        </div>
      ))}
    </div>
    <p class="enterprise muted">
      Ergänzend Berufserfahrung mit <strong>Enterprise-Monitoring (Zabbix)</strong> für
      geschäftskritische Mail-Infrastruktur (Verfügbarkeit, Mailflow, Transport-Queues) in einer
      On-Premise-Umgebung.
    </p>
  </section>

  <section id="principles">
    <h2>Arbeitsweise</h2>
    <ul class="principles">
      <li><strong>Fail-open statt fragil:</strong> intelligente Features degradieren auf deterministische Heuristiken, statt auszufallen.</li>
      <li><strong>Getestet, nicht angenommen:</strong> Backups werden regelmäßig automatisch wiederhergestellt und auf Integrität geprüft.</li>
      <li><strong>Least exposure:</strong> keine offenen Inbound-Ports, loopback-gebundene Dienste, Secrets getrennt vom Code.</li>
      <li><strong>Dokumentiert &amp; versioniert:</strong> Runbooks, Architektur-Entscheidungen und Configs nachvollziehbar in Git.</li>
    </ul>
  </section>
</BaseLayout>

<style>
  .hero { padding: 64px 0 8px; }
  .kicker { color: var(--accent); font-size: 0.8rem; margin: 0 0 14px; letter-spacing: 0.02em; }
  .hero h1 { font-size: 2.5rem; max-width: 16ch; }
  .intro { font-size: 1.12rem; color: var(--fg-muted); max-width: 62ch; margin-top: 1em; }
  .contact { margin-top: 26px; font-size: 0.85rem; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
  .contact > span:first-child { color: var(--accent); }
  .contact .sep { color: var(--fg-dim); }

  .cards { display: grid; gap: 16px; grid-template-columns: 1fr; }
  @media (min-width: 680px) { .cards { grid-template-columns: 1fr 1fr; } }
  .card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 22px 18px;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.18s, transform 0.18s, background 0.18s;
  }
  .card:hover { border-color: var(--accent-line); transform: translateY(-2px); background: #18202d; text-decoration: none; }
  .card-top { display: flex; justify-content: space-between; align-items: center; }
  .card-n { color: var(--fg-dim); font-size: 0.8rem; }
  .card-arrow { color: var(--accent); opacity: 0; transition: opacity 0.18s; }
  .card:hover .card-arrow { opacity: 1; }
  .card h3 { margin: 12px 0 6px; font-size: 1.12rem; }
  .card p { margin: 0; color: var(--fg-muted); font-size: 0.92rem; line-height: 1.55; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
  .card-tags span { font-size: 0.68rem; color: var(--fg-dim); border: 1px solid var(--border-soft); border-radius: 5px; padding: 2px 7px; }

  .stack { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .stack-row { display: grid; grid-template-columns: 1fr; gap: 2px; padding: 13px 18px; border-bottom: 1px solid var(--border-soft); }
  @media (min-width: 620px) { .stack-row { grid-template-columns: 200px 1fr; gap: 16px; align-items: baseline; } }
  .stack-row:last-child { border-bottom: 0; }
  .stack-group { color: var(--accent); font-size: 0.8rem; }
  .stack-items { color: var(--fg-muted); font-size: 0.92rem; }
  .enterprise { font-size: 0.88rem; margin-top: 18px; line-height: 1.6; max-width: 66ch; }

  .principles { list-style: none; padding: 0; }
  .principles li {
    padding: 12px 0 12px 26px;
    border-bottom: 1px solid var(--border-soft);
    position: relative;
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
  .principles li::before { content: '▸'; color: var(--accent); position: absolute; left: 4px; }
  .principles li:last-child { border-bottom: 0; }
</style>
